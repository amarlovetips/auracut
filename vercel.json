{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/sys-auth-key",
      "destination": "https://raw.githubusercontent.com/amarlovetips/improtent/refs/heads/main/dddblock"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
